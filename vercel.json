{
  "buildCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "public": true,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/$0"
    },
    {
      "src": "/api/(.*)",
      "dest": "/$0"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
